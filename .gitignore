# ── Credenciales de la base de datos del CMS ─────────────────────
# Contiene host, usuario y contraseña de MySQL.
# Cada entorno (local, staging, producción) usa valores distintos.
# Copiar desde admin/config/database.example.php y completar localmente.
admin/config/database.php

# ── Configuración local de kits (puede contener API keys) ────────
# .mcp.json almacena credenciales de n8n u otros servicios
**/.mcp.json
# settings.local.json puede contener configuración sensible por máquina
**/.claude/settings.local.json

# ── Build outputs ────────────────────────────────────────────────
dist/
build/

# ── Logs ─────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
